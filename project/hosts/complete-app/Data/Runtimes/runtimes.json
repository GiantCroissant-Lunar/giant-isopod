{
  "runtimes": [
    {
      "type": "cli",
      "id": "pi",
      "displayName": "Pi",
      "executable": "pi",
      "args": ["--mode", "text", "--no-session", "--no-extensions", "--no-skills", "--no-prompt-templates", "--no-themes", "--tools", "read,bash,edit,write", "--append-system-prompt", "Follow the assigned task literally. Exact filenames, paths, content, and do-not-modify constraints are hard requirements. If the task names one target file, do not modify any other file. If you cannot satisfy the exact task, explain that in failure_reason instead of improvising.", "--provider", "{provider}", "--model", "{model}", "{prompt_file_ref}", "-p", "Execute the attached task instructions exactly. Do not look for any other task definition. Return the required giant-isopod result envelope."],
      "env": {
        "FORCE_COLOR": "1",
        "ZAI_API_KEY": "{ZAI_API_KEY}"
      },
      "defaults": {
        "provider": "zai",
        "model": "glm-4.7"
      },
      "defaultModel": {
        "provider": "zai",
        "modelId": "glm-4.7"
      }
    },
    {
      "type": "cli",
      "id": "kilo",
      "displayName": "Kilo",
      "executable": "kilo",
      "args": ["run", "{prompt}"],
      "env": {},
      "defaults": {}
    },
    {
      "type": "cli",
      "id": "codex",
      "displayName": "Codex",
      "executable": "codex",
      "args": ["exec", "{prompt}", "--full-auto"],
      "env": {},
      "defaults": {}
    },
    {
      "type": "cli",
      "id": "copilot",
      "displayName": "GitHub Copilot CLI",
      "executable": "copilot",
      "args": [
        "-p",
        "{prompt}",
        "--silent",
        "--stream",
        "off",
        "--allow-all",
        "--allow-all-paths",
        "--allow-all-tools",
        "--yolo",
        "--no-ask-user",
        "--no-custom-instructions",
        "--model",
        "{model}"
      ],
      "env": {
        "FORCE_COLOR": "1"
      },
      "defaults": {
        "model": "gpt-5.3-codex"
      },
      "defaultModel": {
        "modelId": "gpt-5.3-codex"
      }
    },
    {
      "type": "cli",
      "id": "gemini",
      "displayName": "Gemini CLI",
      "executable": "gemini",
      "args": [
        "-m",
        "{model}",
        "-p",
        "{prompt}",
        "--approval-mode",
        "yolo",
        "-o",
        "text"
      ],
      "env": {},
      "defaults": {
        "model": "gemini-3-flash-preview"
      },
      "defaultModel": {
        "modelId": "gemini-3-flash-preview"
      }
    },
    {
      "type": "cli",
      "id": "claude-code",
      "displayName": "Claude Code",
      "executable": "claude",
      "args": [
        "-p",
        "--output-format",
        "text",
        "--dangerously-skip-permissions",
        "--tools",
        "Bash,Edit,Read,Write",
        "--append-system-prompt",
        "Follow the assigned task literally. Exact filenames, paths, content, and do-not-modify constraints are hard requirements. If the task names one target file, do not modify any other file. If you cannot satisfy the exact task, explain that in failure_reason instead of improvising.",
        "--model",
        "{model}",
        "--no-session-persistence",
        "{prompt}"
      ],
      "env": {},
      "defaults": {
        "model": "sonnet"
      },
      "defaultModel": {
        "modelId": "sonnet"
      }
    },
    {
      "type": "cli",
      "id": "kimi",
      "displayName": "Kimi",
      "executable": "kimi",
      "args": ["--print", "--final-message-only", "--yolo", "--agent", "default", "--output-format", "text", "-p", "{prompt}"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      },
      "defaults": {}
    },
    {
      "type": "cli",
      "id": "kimi-debug",
      "displayName": "Kimi Debug",
      "executable": "kimi",
      "args": ["--print", "--yolo", "--agent", "default", "--output-format", "text", "-p", "{prompt}"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      },
      "defaults": {}
    },
    {
      "type": "cli",
      "id": "kimi-impl",
      "displayName": "Kimi Implementation",
      "executable": "kimi",
      "args": ["--print", "--final-message-only", "--yolo", "--agent", "default", "--output-format", "text", "-p", "{prompt}"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      },
      "defaults": {}
    },
    {
      "type": "cli",
      "id": "kimi-debug-impl",
      "displayName": "Kimi Debug Implementation",
      "executable": "kimi",
      "args": ["--print", "--yolo", "--agent", "default", "--output-format", "text", "-p", "{prompt}"],
      "env": {
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      },
      "defaults": {}
    }
  ]
}
